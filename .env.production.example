# =============================================================================
# ABDiploma Hub — production environment template
# =============================================================================
# Copy values into your host's secret store / .env (never commit real secrets).
# Frontend vars are baked in at `npm run build`. Backend vars are read at runtime.
# =============================================================================

# ---------------------------------------------------------------------------
# Frontend (Vite — set before `npm run build` in frontend/)
# ---------------------------------------------------------------------------

# Public API origin. Prefer empty for same-origin reverse proxy (/api → backend).
# Example split deploy: https://api.abdiplomahub.com
VITE_API_URL=

# Canonical site origin (no trailing slash). Used for SEO, OG, JSON-LD.
VITE_SITE_URL=https://abdiplomahub.com

# Google Analytics 4 measurement ID (leave blank to disable)
VITE_GA_MEASUREMENT_ID=

# Sentry browser DSN (public in the JS bundle; leave blank to disable)
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Backend (FastAPI — runtime in backend/)
# ---------------------------------------------------------------------------

APP_NAME=ABDiploma Hub API
ENVIRONMENT=production
APP_VERSION=1.0.0

# SQLite path or Postgres URL. Prefer Postgres for multi-instance production.
DATABASE_URL=sqlite:///./albertaprep.db

# Browser origin(s) allowed for CORS (comma-separated, never "*").
# Must match the public site URL(s), including www if used.
FRONTEND_URL=https://abdiplomahub.com

# Signing secret — REQUIRED in production.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Prefer a dedicated secret; falls back to SECRET_KEY if empty.
GUEST_QUIZ_SIGNING_SECRET=

# Admin access (use either or both)
ADMIN_API_KEY=
ADMIN_EMAILS=you@example.com

# Session / cookies — Secure defaults to true when ENVIRONMENT=production
SESSION_TTL_HOURS=168
AUTH_COOKIE_NAME=albertaprep_session
# Leave unset for production auto-Secure; set false only for emergency local HTTPS debug
# AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax

# Docs off in production
ENABLE_API_DOCS=false

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=30
MAX_REQUEST_BODY_BYTES=65536

# Observability — Sentry activates when ENVIRONMENT=production AND DSN is set
SENTRY_DSN=
STRUCTURED_LOGGING=true
SLOW_REQUEST_THRESHOLD_MS=1000

# HSTS — defaults to on when ENVIRONMENT=production (HTTPS only)
# ENABLE_HSTS=true

# Database backups (directory must NOT be web-served)
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
