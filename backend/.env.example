# Copy to .env and adjust values.

APP_NAME=ABDiploma Hub API
ENVIRONMENT=development
APP_VERSION=1.0.0

# Admin access — use either or both.
ADMIN_API_KEY=
ADMIN_EMAILS=

DATABASE_URL=sqlite:///./albertaprep.db

# Required in production (see ../.env.production.example)
SECRET_KEY=

SESSION_TTL_HOURS=168

RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_PER_MINUTE=10
RATE_LIMIT_PUBLIC_PER_MINUTE=30

ENABLE_API_DOCS=true
FRONTEND_URL=http://localhost:5173,http://127.0.0.1:5173
MAX_REQUEST_BODY_BYTES=65536
GUEST_QUIZ_SIGNING_SECRET=

# Observability — Sentry only activates when ENVIRONMENT=production AND DSN is set.
SENTRY_DSN=
STRUCTURED_LOGGING=false
SLOW_REQUEST_THRESHOLD_MS=1000

# HSTS off in development (auto-on in production)
ENABLE_HSTS=false

# Database backups (directory must NOT be served by the web server)
BACKUP_DIR=backups
BACKUP_RETENTION_DAYS=14
