# Frontend environment variables (Vite).
# Copy to .env.local for local overrides.
# Production: see ../.env.production.example

# Public API origin. Leave empty for same-origin /api (Vite proxy in dev).
VITE_API_URL=

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable.
VITE_GA_MEASUREMENT_ID=

# Absolute site origin used for canonical URLs, Open Graph, and JSON-LD (no trailing slash).
# Also drives public/robots.txt and public/sitemap.xml via `npm run build`.
VITE_SITE_URL=https://abdiplomahub.com

# Sentry browser DSN (optional). Only initialized in production builds when set.
# Never put server secrets here — this value is public in the JS bundle.
VITE_SENTRY_DSN=
